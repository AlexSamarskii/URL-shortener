# Server
PORT=8080

# Storage (memory only supported in this version)
STORAGE_TYPE=memory

# Short code settings
SHORT_CODE_LENGTH=10

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SEC=60

# Bloom filter
BLOOM_N=1000000
BLOOM_P=0.001

# Domain for short URLs
DOMAIN=http://localhost:8081

# Metrics
ENABLE_METRICS=true